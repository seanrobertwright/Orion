# Normalize all text files to LF on commit
* text=auto eol=lf

# Explicitly declare common text files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.sql  text eol=lf
*.env* text eol=lf

# Binary files — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
